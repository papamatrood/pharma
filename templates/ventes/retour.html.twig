{% extends 'layout/layout.html.twig' %}

{% block title %}Liste des ventes{% endblock %}

{% block body %}
    <div class="containerBackground">
        <h3>Liste des produits ventes</h3>
        <br/>
        {% for message in app.flashes('errors') %}
            <div class="alert alert-danger">
                    {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                    {{ message }}
            </div>
        {% endfor %}

        <form class="form-inline" method="GET">
            <input name="recherche" class="form-control" type="date" value="{{ recherche|date("Y-m-d") }}">
            <button type="submit" class="btn btn-primary">Recherche</button>
        </form>
        <br/>

        <table class="table table-bordered">
            <thead class="thead-light">
                <tr>
                    <th>Référence</th>
                    <th>Client</th>
                    <th>Produits</th>
                    <th>Quantité</th>
                    <th>Montant TTC</th>
                    <th>Date de la vente</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for vente in ventes %}
                {% set total = 0 %}
                <tr>
                    <td>{{ vente.reference }}</td>
                    <td>{{ vente.produits.nomClient }}</td>
                    <td>
                        {% for produit in vente.produits.produits %}
                            {{ produit.designationProduit }} <br/>
                        {% endfor %}
                    </td>
                    <td>
                        {% for produit in vente.produits.produits %}
                            {{ produit.quantite }} <br/>
                        {% endfor %}
                    </td>
                    <td>
                        {% for produit in vente.produits.produits %}
                            {% set total = total + produit.net %}
                        {% endfor %}
                        {{ total|number_format(0, ' ', ' ') }} FCFA
                    </td>
                    <td>{{ vente.dateventeAt ? vente.dateventeAt|date('Y-m-d H:i:s') : '' }}</td>
                    <td>
                        <a class="btn btn-outline-primary" href="{{ path('ventes_edit', {'idVente': vente.id}) }}"><i class="far fa-edit"></i></a>
                        <form method="post" action="{{ path('ventes_delete', {'id': vente.id}) }}" class="d-inline-block" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément?');">
                            <input type="hidden" name="_method" value="DELETE">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vente.id) }}">
                            <button class="btn btn-outline-danger"><i class="far fa-trash-alt"></i></button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Aucun enregistrement trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <a class="btn btn-outline-primary" href="{{ path('ventes_new') }}">Effectuer une vente</a>
    </div>
{% endblock %}
